{
  "name": "pokenauts-integration",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone integration service for Discord/Pokenauts and a self-hosted Pokemon Showdown server.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "register:commands": "tsx src/registerCommands.ts",
    "test:pokenauts": "tsx src/pokenautsFlow.test.ts"
  },
  "dependencies": {
    "discord.js": "^14.18.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
